#!/bin/bash
set -euo pipefail

APP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
RES="$APP_ROOT/Resources"
VERSION_FILE="$RES/runtime/version.env"
if [[ ! -r "$VERSION_FILE" ]]; then
  /usr/bin/osascript -e 'display alert "Brainana Align" message "Version metadata is missing. Reinstall the complete application." as critical' >/dev/null 2>&1 || true
  exit 32
fi
# shellcheck disable=SC1090
. "$VERSION_FILE"
if [[ -z "${VERSION:-}" || -z "${BUILD_ID:-}" ]]; then
  /usr/bin/osascript -e 'display alert "Brainana Align" message "Version metadata is invalid. Reinstall the complete application." as critical' >/dev/null 2>&1 || true
  exit 32
fi

show_error() {
  local message="$1"
  /usr/bin/osascript -e 'on run a' -e 'display alert "Brainana Align" message (item 1 of a) as critical buttons {"OK"}' -e 'end run' -- "$message" >/dev/null 2>&1 || true
}

on_error() {
  local rc=$?
  local line="$1"
  show_error "The launcher stopped unexpectedly at line $line (error $rc). See the launch log in ~/Library/Application Support/Brainana Align/logs/."
  exit "$rc"
}
trap 'on_error $LINENO' ERR

PROCESS_ARCH="$(/usr/bin/uname -m)"
HARDWARE_ARM64="$(/usr/sbin/sysctl -n hw.optional.arm64 2>/dev/null || printf '0')"
ROSETTA_TRANSLATED="$(/usr/sbin/sysctl -in sysctl.proc_translated 2>/dev/null || printf '0')"
if [[ "$HARDWARE_ARM64" == "1" ]]; then
  HARDWARE_ARCH="arm64"
  NODE="$RES/runtime/darwin-arm64/node"
elif [[ "$PROCESS_ARCH" == "x86_64" ]]; then
  HARDWARE_ARCH="x86_64"
  NODE="$RES/runtime/darwin-x64/node"
else
  show_error "Unsupported Mac architecture. Process architecture: $PROCESS_ARCH; arm64 hardware flag: $HARDWARE_ARM64"
  exit 31
fi
[[ -x "$NODE" ]] || { show_error "Bundled runtime missing for $HARDWARE_ARCH. Reinstall the complete application."; exit 33; }

SUPPORT="$HOME/Library/Application Support/Brainana Align"
CACHE="$HOME/Library/Caches/Brainana Align/$VERSION"
LOGS="$SUPPORT/logs"
PROFILES="$SUPPORT/profiles.tsv"
mkdir -p "$SUPPORT" "$CACHE" "$LOGS"
touch "$PROFILES"
chmod 600 "$PROFILES"
LOG_FILE="$LOGS/launch-$(/bin/date +%Y%m%d-%H%M%S)-$$.log"
exec > >(tee -a "$LOG_FILE") 2>&1

INSTANCE_DIR="$SUPPORT/instance"
ACTIVE_INSTANCE="$INSTANCE_DIR/active.json"
/bin/mkdir -p "$INSTANCE_DIR"
/bin/chmod 700 "$INSTANCE_DIR" 2>/dev/null || true

json_number_field() {
  local file="$1" field="$2"
  /usr/bin/sed -n "s/.*\"$field\":[[:space:]]*\([0-9][0-9]*\).*/\1/p" "$file" | /usr/bin/head -n 1
}
json_string_field() {
  local file="$1" field="$2"
  /usr/bin/sed -n "s/.*\"$field\":[[:space:]]*\"\([^\"]*\)\".*/\1/p" "$file" | /usr/bin/head -n 1
}
clear_stale_instance() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  local old_pid old_socket old_target old_label old_cmd
  old_pid="$(json_number_field "$file" pid)"
  old_socket="$(json_string_field "$file" controlSocket)"
  old_target="$(json_string_field "$file" sshTarget)"
  old_label="$(json_string_field "$file" launchLabel)"
  if [[ -n "$old_label" ]]; then
    /bin/launchctl remove "$old_label" >/dev/null 2>&1 || true
  fi
  if [[ "$old_pid" =~ ^[0-9]+$ ]] && kill -0 "$old_pid" 2>/dev/null; then
    old_cmd="$(/bin/ps -p "$old_pid" -o command= 2>/dev/null || true)"
    if [[ "$old_cmd" == *"Brainana Align.app/Contents/Resources/runtime/server.mjs"* || "$old_cmd" == *"/runtime/server.mjs"* ]]; then
      kill "$old_pid" 2>/dev/null || true
      /bin/sleep 0.1
    fi
  fi
  if [[ -n "$old_socket" && -n "$old_target" ]]; then
    /usr/bin/ssh -S "$old_socket" -O exit "$old_target" >/dev/null 2>&1 || true
  fi
  /bin/rm -f "$file"
}
reopen_matching_instance() {
  local selected_mode="$1"
  local selected_root="$2"
  local selected_target="$3"
  local selected_profile="$4"
  [[ -s "$ACTIVE_INSTANCE" ]] || return 1
  local existing_pid existing_port existing_token existing_version existing_mode existing_root existing_target existing_profile base_url url
  existing_pid="$(json_number_field "$ACTIVE_INSTANCE" pid)"
  existing_port="$(json_number_field "$ACTIVE_INSTANCE" port)"
  existing_token="$(json_string_field "$ACTIVE_INSTANCE" sessionToken)"
  existing_version="$(json_string_field "$ACTIVE_INSTANCE" version)"
  existing_mode="$(json_string_field "$ACTIVE_INSTANCE" mode)"
  existing_root="$(json_string_field "$ACTIVE_INSTANCE" dataRoot)"
  existing_target="$(json_string_field "$ACTIVE_INSTANCE" sshTarget)"
  existing_profile="$(json_string_field "$ACTIVE_INSTANCE" profile)"
  if [[ ! "$existing_pid" =~ ^[0-9]+$ || ! "$existing_port" =~ ^[0-9]+$ || ! "$existing_token" =~ ^[0-9A-Fa-f]{64,}$ || "$existing_version" != "$VERSION" ]]; then
    clear_stale_instance "$ACTIVE_INSTANCE"
    return 1
  fi
  if ! kill -0 "$existing_pid" 2>/dev/null; then
    clear_stale_instance "$ACTIVE_INSTANCE"
    return 1
  fi
  if [[ "$existing_mode" != "$selected_mode" || "$existing_root" != "$selected_root" || "$existing_target" != "$selected_target" || "$existing_profile" != "$selected_profile" ]]; then
    echo "An existing Brainana Align session does not match the newly selected mode/profile; replacing it."
    clear_stale_instance "$ACTIVE_INSTANCE"
    return 1
  fi
  base_url="http://127.0.0.1:$existing_port"
  if /usr/bin/curl --noproxy '*' --connect-timeout 0.35 --max-time 1.0 -fsS "$base_url/api/health" -H "X-Brainana-Session: $existing_token" >/dev/null 2>&1; then
    url="$base_url/#session=$existing_token"
    echo "Reopening matching Brainana Align session on port $existing_port (server PID $existing_pid)."
    /usr/bin/open "$url" >/dev/null 2>&1 &
    return 0
  fi
  clear_stale_instance "$ACTIVE_INSTANCE"
  return 1
}


ask() {
  /usr/bin/osascript -e 'on run a' -e 'text returned of (display dialog (item 1 of a) default answer (item 2 of a) with title "Brainana Align")' -e 'end run' -- "$1" "${2:-}"
}
choose_mode() {
  /usr/bin/osascript -e 'set p to choose from list {"Local files on this Mac", "Remote workstation"} with title "Brainana Align" with prompt "Choose how to access data:" default items {"Local files on this Mac"}' -e 'if p is false then error number -128' -e 'item 1 of p'
}
choose_folder() {
  /usr/bin/osascript -e 'POSIX path of (choose folder with prompt "Choose the folder containing MRI and CT data")'
}
notice() {
  /usr/bin/osascript -e 'on run a' -e 'display dialog (item 1 of a) with title "Brainana Align" buttons {"Continue"} default button "Continue"' -e 'end run' -- "$1" >/dev/null
}
choose_profile() {
  local choices_file="$CACHE/profile-choices-$$.txt"
  /usr/bin/awk -F '\t' 'NF && $1 != "" {print $1}' "$PROFILES" > "$choices_file"
  printf '%s\n' 'Add a new connection...' >> "$choices_file"
  /usr/bin/osascript - "$choices_file" <<'APPLESCRIPT'
on run argv
  set choicesFile to POSIX file (item 1 of argv)
  set rawText to read choicesFile as «class utf8»
  set rawChoices to paragraphs of rawText
  set choices to {}
  repeat with c in rawChoices
    set t to c as text
    if t is not "" then set end of choices to t
  end repeat
  set p to choose from list choices with title "Brainana Align" with prompt "Choose a connection:" default items {item 1 of choices}
  if p is false then error number -128
  return item 1 of p
end run
APPLESCRIPT
  local rc=$?
  rm -f "$choices_file"
  return "$rc"
}
shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | /usr/bin/sed "s/'/'\\''/g")"
}
open_interactive_ssh() {
  local target="$1"
  local socket="$2"
  local auth_dir="$CACHE/ssh-auth-$$-${RANDOM:-0}"
  local status_file="$auth_dir/status"
  local pid_file="$auth_dir/helper.pid"
  local helper="$auth_dir/run-ssh-auth.command"
  local started_file="$auth_dir/started"
  local diagnostic_file="$auth_dir/ssh-diagnostic.log"
  /bin/rm -rf "$auth_dir"
  /bin/mkdir -p "$auth_dir"
  /bin/chmod 700 "$auth_dir"
  /bin/rm -f "$socket"

  # Run interactive authentication in a dedicated helper. The EXIT/HUP/INT/TERM
  # traps guarantee a terminal close or Ctrl-C publishes a cancellation result,
  # allowing the .app launcher to exit promptly instead of remaining alive and
  # causing later Dock launches to bounce without reopening the chooser.
  {
    printf '#!/bin/bash\n'
    printf 'set +e\n'
    printf 'STATUS_FILE=%q\n' "$status_file"
    printf 'PID_FILE=%q\n' "$pid_file"
    printf 'STARTED_FILE=%q\n' "$started_file"
    printf 'DIAGNOSTIC_FILE=%q\n' "$diagnostic_file"
    printf 'write_status() { local rc="$1"; local tmp="${STATUS_FILE}.tmp.$$"; [[ -e "$STATUS_FILE" ]] || { printf "%%s\\n" "$rc" > "$tmp" && /bin/mv -f "$tmp" "$STATUS_FILE"; }; }\n'
    printf 'cancelled() { write_status 130; exit 130; }\n'
    printf 'trap cancelled HUP INT TERM\n'
    printf '%s\n' "trap 'rc=\$?; write_status \"\$rc\"' EXIT"
    printf 'printf "%%s\\n" "$$" > "$PID_FILE"\n'
    printf 'printf "started\\n" > "$STARTED_FILE"\n'
    printf 'printf "SSH helper started at %%s\\n" "$(/bin/date -u +%%Y-%%m-%%dT%%H:%%M:%%SZ)" > "$DIAGNOSTIC_FILE"\n'
    printf '/usr/bin/ssh -M -S %q -o ControlPersist=600 -o ExitOnForwardFailure=yes -NT %q\n' "$socket" "$target"
    printf 'rc=$?\nwrite_status "$rc"\nexit "$rc"\n'
  } > "$helper"
  /bin/chmod 700 "$helper"

  echo "Launching SSH authentication helper in Terminal: $helper"
  if ! /usr/bin/open -a Terminal "$helper" >/dev/null 2>&1; then
    /bin/rm -rf "$auth_dir"
    show_error "Brainana Align could not open the SSH authentication helper in Terminal. Verify that Terminal.app is installed and allowed to open .command files."
    return 1
  fi

  # Require positive acknowledgement that Terminal actually executed the helper.
  # A successful `open` only means LaunchServices accepted the request; it does
  # not prove that Terminal ran the script.
  local startup_i=0
  while [[ $startup_i -lt 80 && ! -s "$started_file" && ! -s "$status_file" ]]; do
    /bin/sleep 0.1
    startup_i=$((startup_i+1))
  done
  if [[ ! -s "$started_file" && ! -s "$status_file" ]]; then
    /bin/rm -rf "$auth_dir"
    show_error "Terminal opened, but the SSH authentication helper did not start. Check Terminal privacy/security settings and try again."
    return 1
  fi
  echo "SSH authentication helper acknowledged startup."

  local i=0 helper_pid="" helper_seen=0
  while [[ $i -lt 1200 ]]; do
    if /usr/bin/ssh -S "$socket" -O check "$target" >/dev/null 2>&1; then
      /bin/rm -rf "$auth_dir"
      return 0
    fi
    if [[ -s "$pid_file" ]]; then
      helper_pid="$(/bin/cat "$pid_file" 2>/dev/null || true)"
      [[ "$helper_pid" =~ ^[0-9]+$ ]] && helper_seen=1
    fi
    if [[ -s "$status_file" ]]; then
      local rc
      rc="$(/bin/cat "$status_file" 2>/dev/null || echo 1)"
      if [[ "$rc" == "130" || "$rc" == "129" || "$rc" == "143" ]]; then
        /bin/rm -rf "$auth_dir"
        echo "SSH authentication to $target was cancelled."
        return 2
      fi
      if [[ "$rc" == "0" ]]; then
        local ready_i=0
        while [[ $ready_i -lt 30 ]]; do
          if /usr/bin/ssh -S "$socket" -O check "$target" >/dev/null 2>&1; then
            /bin/rm -rf "$auth_dir"
            return 0
          fi
          /bin/sleep 0.1
          ready_i=$((ready_i+1))
        done
        echo "SSH diagnostic directory retained: $auth_dir"
        show_error "SSH reported success, but the persistent connection did not become ready. Diagnostics were retained at: $auth_dir"
        return 1
      fi
      echo "SSH diagnostic directory retained: $auth_dir"
      show_error "SSH connection to $target failed (error $rc). Diagnostics were retained at: $auth_dir"
      return 1
    fi
    if [[ "$helper_seen" -eq 1 && "$helper_pid" =~ ^[0-9]+$ ]] && ! kill -0 "$helper_pid" 2>/dev/null; then
      echo "SSH diagnostic directory retained: $auth_dir"
      echo "SSH authentication helper ended before a connection was established."
      return 2
    fi
    /bin/sleep 0.25
    i=$((i+1))
  done
  if [[ "$helper_pid" =~ ^[0-9]+$ ]]; then kill "$helper_pid" >/dev/null 2>&1 || true; fi
  echo "SSH diagnostic directory retained: $auth_dir"
  show_error "SSH authentication did not complete within five minutes. Close the authentication Terminal tab and try again. Diagnostics were retained at: $auth_dir"
  return 1
}

MODE_PICK="$(choose_mode)" || exit 0
MODE="local"
LABEL="This Mac"
PROFILE_NAME="This Mac"
ROOT=""
TARGET=""
SOCKET=""

if [[ "$MODE_PICK" == "Local files on this Mac" ]]; then
  # Local MRI and CT inputs are selected inside the browser through the
  # dedicated Load MRI and Load CT controls. A startup folder chooser adds
  # friction without limiting those browser-selected files. HOME remains the
  # local server safety boundary for any explicit local filesystem API calls.
  ROOT="$HOME"
else
  MODE="remote"
  LABEL="Remote workstation"
  PICK="$(choose_profile)" || exit 0
  if [[ "$PICK" != "Add a new connection..." ]]; then
    LINE="$(/usr/bin/awk -F '\t' -v n="$PICK" '$1==n{print;exit}' "$PROFILES")"
    [[ -n "$LINE" ]] || { show_error "The selected connection profile could not be found."; exit 36; }
    IFS=$'\t' read -r NAME USER HOST ROOT <<EOF_PROFILE
$LINE
EOF_PROFILE
  else
    NAME="$(ask 'Connection name:' 'Workstation')" || exit 0
    USER="$(ask 'Username:' '')" || exit 0
    HOST="$(ask 'Hostname:' '')" || exit 0
    ROOT="$(ask 'Remote data root:' '')" || exit 0
    [[ -n "$NAME" && -n "$USER" && -n "$HOST" && -n "$ROOT" ]] || { show_error "Connection name, username, hostname, and remote data root are all required."; exit 37; }
    printf '%s\t%s\t%s\t%s\n' "$NAME" "$USER" "$HOST" "$ROOT" >> "$PROFILES"
  fi
  PROFILE_NAME="$NAME"
  TARGET="$USER@$HOST"
fi

# Every launch returns to the mode/profile chooser. Local sessions may be
# reopened immediately after selection. Remote sessions deliberately proceed
# through a visible SSH-authentication stage on every launch. This avoids a
# fragile silent-reuse branch that could stop after profile selection without
# either opening the browser or showing the authentication prompt.
echo "Selection complete: mode=$MODE profile=$PROFILE_NAME root=$ROOT target=${TARGET:-none}"
if [[ "$MODE" == "local" ]]; then
  if reopen_matching_instance "$MODE" "$ROOT" "$TARGET" "$PROFILE_NAME"; then
    exit 0
  fi
else
  echo "Remote profile selected. Preparing visible SSH authentication for $TARGET."
  SOCKET="$CACHE/ssh-control-$$"
  if ! notice "A Terminal window will open next for SSH authentication to $TARGET. Complete any password, key passphrase, Duo, or keyboard-interactive prompts there. Canceling or closing that Terminal tab will return Brainana Align to a clean stopped state."; then
    show_error "Brainana Align could not display the SSH authentication notice. Check macOS Automation permissions for Terminal and try again."
    exit 38
  fi
  echo "Opening SSH connection to $TARGET..."
  if open_interactive_ssh "$TARGET" "$SOCKET"; then
    echo "SSH authentication completed successfully."
  else
    rc=$?
    /bin/rm -f "$SOCKET"
    if [[ "$rc" -eq 2 ]]; then
      echo "SSH authentication was cancelled; launcher exiting cleanly."
      exit 0
    fi
    show_error "SSH authentication did not complete. Review the launch log and Terminal output, then try again."
    exit "$rc"
  fi
  # A successful fresh remote authentication replaces any older detached
  # session. Reusing remote state before authentication was the source of a
  # silent-stop regression after selecting a saved profile.
  clear_stale_instance "$ACTIVE_INSTANCE"
fi

echo "Brainana Align"
echo "Version: $VERSION"
echo "Build ID: $BUILD_ID"
echo "Launcher: $0"
echo "Mode: $MODE"
echo "Profile: $PROFILE_NAME"
echo "Browser URL: assigned automatically after server start"
echo "Browser port: assigned automatically by macOS"
echo "Local runtime path: $RES/runtime"
echo "Cache path: $CACHE"
echo "Local Node path: $NODE"
echo "Process architecture: $PROCESS_ARCH"
echo "Hardware architecture: $HARDWARE_ARCH"
echo "Rosetta translation: $([[ "$ROSETTA_TRANSLATED" == "1" ]] && echo yes || echo no)"
echo "Selected runtime: $(/usr/bin/basename "$(/usr/bin/dirname "$NODE")")"
echo "Data root: $ROOT"
echo "Launch log: $LOG_FILE"
if [[ "$MODE" == "remote" ]]; then
  echo "Remote host: $TARGET"
  echo "Remote data root: $ROOT"
  echo "SSH control socket path: $SOCKET"
  echo "Connection status: connected"
fi

# Each launch receives a private handshake directory. This prevents stale files,
# concurrent launches, and prior browser sessions from affecting port discovery.
UMASK_OLD="$(umask)"
umask 077
LAUNCH_TOKEN="$(/bin/date +%Y%m%d-%H%M%S)-$$-${RANDOM:-0}"
LAUNCH_DIR="$CACHE/launch-$LAUNCH_TOKEN"
/bin/mkdir -p "$LAUNCH_DIR"
umask "$UMASK_OLD"
HANDSHAKE_FILE="$LAUNCH_DIR/handshake.json"
ERROR_FILE="$LAUNCH_DIR/server-error.txt"
SERVER_LOG="$LOGS/server-$(/bin/date +%Y%m%d-%H%M%S)-$$.log"
rm -f "$HANDSHAKE_FILE" "$ERROR_FILE"

/usr/bin/find "$CACHE" -maxdepth 1 -type d -name 'launch-*' -mtime +2 -exec /bin/rm -rf {} + >/dev/null 2>&1 || true

ARGS=(--host 127.0.0.1 --port 0 --handshake-file "$HANDSHAKE_FILE" --error-file "$ERROR_FILE" --root "$ROOT" --mode "$MODE" --label "$LABEL" --cache "$CACHE")
[[ "$MODE" == "remote" ]] && ARGS+=(--ssh-target "$TARGET" --control-socket "$SOCKET")

# Submit the server to the per-user launchd domain rather than leaving it as a
# descendant of the .app executable. A lingering descendant can cause
# LaunchServices to treat the app as still running, particularly when remote
# SSH/SFTP children are active, which makes a later Dock launch only bounce.
LAUNCH_LABEL="org.brainana.align.server.${UID}.$$.${RANDOM:-0}"
SERVER_WRAPPER="$LAUNCH_DIR/start-server.sh"
{
  printf '#!/bin/bash\nexec '
  printf '%q ' "$NODE" "$RES/runtime/server.mjs" "${ARGS[@]}"
  printf '>> %q 2>&1 < /dev/null\n' "$SERVER_LOG"
} > "$SERVER_WRAPPER"
/bin/chmod 700 "$SERVER_WRAPPER"
/bin/launchctl submit -l "$LAUNCH_LABEL" -- /bin/bash "$SERVER_WRAPPER"
PID=""
SERVER_OWNERSHIP_TRANSFERRED=0
cleanup() {
  if [[ "$SERVER_OWNERSHIP_TRANSFERRED" -ne 1 ]]; then
    /bin/launchctl remove "$LAUNCH_LABEL" >/dev/null 2>&1 || true
    if [[ "$PID" =~ ^[0-9]+$ ]]; then kill "$PID" 2>/dev/null || true; fi
    if [[ -n "${SOCKET:-}" && -n "${TARGET:-}" ]]; then
      /usr/bin/ssh -S "$SOCKET" -O exit "$TARGET" >/dev/null 2>&1 || true
    fi
  fi
  /bin/rm -rf "$LAUNCH_DIR"
}
trap cleanup EXIT

echo "Waiting for the bundled server to publish its secure launch handshake..."
PORT=""
SESSION_TOKEN=""
ATTEMPT=0
while [[ $ATTEMPT -lt 600 ]]; do
  if [[ -s "$HANDSHAKE_FILE" ]]; then
    HANDSHAKE_JSON="$(/bin/cat "$HANDSHAKE_FILE" 2>/dev/null || true)"
    PORT="$(printf '%s' "$HANDSHAKE_JSON" | /usr/bin/sed -n 's/.*"port":[[:space:]]*\([0-9][0-9]*\).*/\1/p')"
    SESSION_TOKEN="$(printf '%s' "$HANDSHAKE_JSON" | /usr/bin/sed -n 's/.*"sessionToken":[[:space:]]*"\([0-9A-Fa-f][0-9A-Fa-f]*\)".*/\1/p')"
    PID="$(printf '%s' "$HANDSHAKE_JSON" | /usr/bin/sed -n 's/.*"pid":[[:space:]]*\([0-9][0-9]*\).*/\1/p')"
    if [[ "$PORT" =~ ^[0-9]+$ ]] && [[ "$PORT" -ge 1 ]] && [[ "$PORT" -le 65535 ]] && [[ "$SESSION_TOKEN" =~ ^[0-9A-Fa-f]{64,}$ ]] && [[ "$PID" =~ ^[0-9]+$ ]]; then
      break
    fi
    PORT=""; SESSION_TOKEN=""
  fi
  if [[ -s "$ERROR_FILE" ]]; then
    SERVER_ERROR="$(/bin/cat "$ERROR_FILE" 2>/dev/null || true)"
    show_error "The local Brainana Align server could not start: ${SERVER_ERROR:-unknown server error}. See $SERVER_LOG for details."
    exit 34
  fi
  if ! /bin/launchctl print "gui/${UID}/${LAUNCH_LABEL}" >/dev/null 2>&1; then
    SERVER_ERROR="$(/bin/cat "$ERROR_FILE" 2>/dev/null || true)"
    show_error "The local Brainana Align server launch job stopped before publishing its launch handshake. ${SERVER_ERROR:-See the server log for details.} Log: $SERVER_LOG"
    exit 34
  fi
  /bin/sleep 0.05
  ATTEMPT=$((ATTEMPT + 1))
done

if [[ -z "$PORT" || -z "$SESSION_TOKEN" ]]; then
  show_error "The local Brainana Align server is still running but did not publish a valid launch handshake within 30 seconds. See $SERVER_LOG for details."
  exit 34
fi

BASE_URL="http://127.0.0.1:$PORT"
URL="$BASE_URL/#session=$SESSION_TOKEN"
echo "Browser URL: $BASE_URL (session token omitted from log)"
echo "Browser port: $PORT"
echo "Server PID: $PID"
echo "Server log: $SERVER_LOG"
echo "Waiting for the matching local health endpoint..."

READY=0
ATTEMPT=0
while [[ $ATTEMPT -lt 400 ]]; do
  if /usr/bin/curl --noproxy '*' --connect-timeout 0.25 --max-time 0.75 -fsS "$BASE_URL/api/health" -H "X-Brainana-Session: $SESSION_TOKEN" >/dev/null 2>&1; then READY=1; break; fi
  if [[ -s "$ERROR_FILE" ]]; then
    SERVER_ERROR="$(/bin/cat "$ERROR_FILE" 2>/dev/null || true)"
    show_error "The local Brainana Align server reported an error before becoming ready: ${SERVER_ERROR:-unknown server error}. See $SERVER_LOG for details."
    exit 34
  fi
  if ! kill -0 "$PID" 2>/dev/null; then
    show_error "The local Brainana Align server stopped before becoming ready. See $SERVER_LOG for details."
    exit 34
  fi
  /bin/sleep 0.05
  ATTEMPT=$((ATTEMPT + 1))
done
[[ "$READY" -eq 1 ]] || { show_error "The local Brainana Align server did not become ready within 20 seconds. See $SERVER_LOG for details."; exit 34; }

INSTANCE_TMP="$ACTIVE_INSTANCE.tmp.$$"
printf '{"schemaVersion":3,"version":"%s","buildId":"%s","pid":%s,"port":%s,"sessionToken":"%s","mode":"%s","profile":"%s","dataRoot":"%s","controlSocket":"%s","sshTarget":"%s","serverLog":"%s","launchLabel":"%s"}\n' \
  "$VERSION" "$BUILD_ID" "$PID" "$PORT" "$SESSION_TOKEN" "$MODE" "$PROFILE_NAME" "$ROOT" "${SOCKET:-}" "${TARGET:-}" "$SERVER_LOG" "$LAUNCH_LABEL" > "$INSTANCE_TMP"
/bin/chmod 600 "$INSTANCE_TMP"
/bin/mv -f "$INSTANCE_TMP" "$ACTIVE_INSTANCE"
SERVER_OWNERSHIP_TRANSFERRED=1

echo "Local server ready. Opening the macOS default browser: $URL"
/usr/bin/open "$URL" >/dev/null 2>&1 &
echo "Browser launch requested. The launcher will now exit while the server remains available for relaunch."
exit 0
