#!/bin/bash
set -u

BUNDLE_ID="org.brainana.viewerlauncher.localremote"
APP_VERSION="2.1.1"
BUILD_ID="2026-07-13-modal-stacking-1"
APP_SUPPORT="$HOME/Library/Application Support/Brainana Viewer Launcher"
PROFILES_FILE="$APP_SUPPORT/remote-data-connections.tsv"

show_message() {
  /usr/bin/osascript -e 'on run argv' \
    -e 'display dialog (item 1 of argv) buttons {"OK"} default button "OK"' \
    -e 'end run' -- "$1" >/dev/null
}
notify() {
  /usr/bin/osascript -e 'on run argv' \
    -e 'display notification (item 1 of argv) with title "Brainana Viewer Launcher"' \
    -e 'end run' -- "$1" >/dev/null 2>&1 || true
}
ask_text() {
  /usr/bin/osascript -e 'on run argv' \
    -e 'display dialog (item 1 of argv) default answer (item 2 of argv) buttons {"Cancel", "Continue"} default button "Continue"' \
    -e 'text returned of result' -e 'end run' -- "$1" "$2"
}
ask_yes_no() {
  /usr/bin/osascript -e 'on run argv' \
    -e 'display dialog (item 1 of argv) buttons {"No", "Yes"} default button "Yes"' \
    -e 'button returned of result' -e 'end run' -- "$1"
}
choose_mode() {
  /usr/bin/osascript -e 'set choices to {"Remote workstation", "Local Mac data"}' \
    -e 'set picked to choose from list choices with title "Brainana Viewer Launcher" with prompt "Where are the Brainana data located?" default items {"Remote workstation"} OK button name "Continue" cancel button name "Cancel"' \
    -e 'if picked is false then error number -128' -e 'item 1 of picked'
}
choose_from_lines() {
  local title="$1" prompt="$2" default_item="$3"; shift 3
  /usr/bin/osascript - "$title" "$prompt" "$default_item" "$@" <<'APPLESCRIPT'
on run argv
  set dialogTitle to item 1 of argv
  set dialogPrompt to item 2 of argv
  set defaultItem to item 3 of argv
  set choiceList to items 4 thru -1 of argv
  set defaultChoices to {}
  if defaultItem is not "" then set defaultChoices to {defaultItem}
  set picked to choose from list choiceList with title dialogTitle with prompt dialogPrompt default items defaultChoices OK button name "Continue" cancel button name "Cancel"
  if picked is false then error number -128
  return item 1 of picked
end run
APPLESCRIPT
}
choose_folder() {
  local prompt="$1" default_path="$2"
  if [[ -d "$default_path" ]]; then
    /usr/bin/osascript -e 'on run argv' -e 'set f to choose folder with prompt (item 1 of argv) default location (POSIX file (item 2 of argv))' -e 'POSIX path of f' -e 'end run' -- "$prompt" "$default_path"
  else
    /usr/bin/osascript -e 'on run argv' -e 'set f to choose folder with prompt (item 1 of argv)' -e 'POSIX path of f' -e 'end run' -- "$prompt"
  fi
}
read_default() { local v; v="$(/usr/bin/defaults read "$BUNDLE_ID" "$1" 2>/dev/null || true)"; [[ -n "$v" ]] && printf '%s' "$v" || printf '%s' "$2"; }
save_default() { /usr/bin/defaults write "$BUNDLE_ID" "$1" "$2" >/dev/null 2>&1 || true; }
normalize_port() {
  local value="${1:-}" fallback="${2:-5173}"
  if [[ "$value" =~ ^[0-9]+$ ]] && ((value >= 1024 && value <= 65435)); then
    printf '%s' "$value"
  else
    printf '%s' "$fallback"
  fi
}
port_is_free() {
  local port="$1"
  if [[ -x /usr/bin/nc ]]; then
    ! /usr/bin/nc -z -w 1 127.0.0.1 "$port" >/dev/null 2>&1
    return
  fi
  if [[ -x /usr/sbin/lsof ]]; then
    ! /usr/sbin/lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
    return
  fi
  return 0
}
find_free_port() {
  local requested="${1:-}" fallback="${2:-5173}" p max
  p="$(normalize_port "$requested" "$fallback")"
  max=$((p + 200))
  ((max > 65535)) && max=65535
  while ((p <= max)); do
    if port_is_free "$p"; then
      printf '%s' "$p"
      return 0
    fi
    p=$((p + 1))
  done
  return 1
}
random_port() {
  local value
  value="$(/usr/bin/od -An -N4 -tu4 /dev/urandom | /usr/bin/tr -d ' ')"
  printf '%s' $((20000 + (value % 40000)))
}
sanitize() { printf '%s' "$1" | tr '\t\r\n' '   '; }

ensure_profiles_file() {
  /bin/mkdir -p "$APP_SUPPORT"
  if [[ ! -f "$PROFILES_FILE" ]]; then
    : > "$PROFILES_FILE"
    printf 'Penn workstation\tekim\t128.91.12.238\t/mnt/DataDrive3/swap/test_brainana/preproc/frosty/preprocessed\t5273\n' >> "$PROFILES_FILE"
    printf 'Bigbox\tmsl1\tbigbox.med.harvard.edu\t/data/brainana/output\t5273\n' >> "$PROFILES_FILE"
  fi
  chmod 600 "$PROFILES_FILE"
}
profile_names() { awk -F '\t' 'NF>=5{print $1}' "$PROFILES_FILE"; }
load_profile() {
  local line; line="$(awk -F '\t' -v n="$1" '$1==n{print;exit}' "$PROFILES_FILE")"; [[ -n "$line" ]] || return 1
  IFS=$'\t' read -r PROFILE_NAME USERNAME HOST OUTPUT_DIR PROFILE_PORT <<< "$line"
}
save_profile() {
  local old="$1" name="$2" user="$3" host="$4" data="$5" port="$6" tmp
  tmp="$(/usr/bin/mktemp -t brainana-viewer-profiles.XXXXXX)" || return 1
  awk -F '\t' -v n="$old" '$1!=n' "$PROFILES_FILE" > "$tmp"
  printf '%s\t%s\t%s\t%s\t%s\n' "$(sanitize "$name")" "$(sanitize "$user")" "$(sanitize "$host")" "$(sanitize "$data")" "$(sanitize "$port")" >> "$tmp"
  mv "$tmp" "$PROFILES_FILE"; chmod 600 "$PROFILES_FILE"
}
delete_profile() { local tmp; tmp="$(/usr/bin/mktemp -t brainana-viewer-profiles.XXXXXX)" || return 1; awk -F '\t' -v n="$1" '$1!=n' "$PROFILES_FILE" > "$tmp"; mv "$tmp" "$PROFILES_FILE"; chmod 600 "$PROFILES_FILE"; }

bundled_node() {
  local app_root="$1" arch node
  arch="$(/usr/bin/uname -m)"
  case "$arch" in
    arm64) node="$app_root/Resources/node/darwin-arm64/node" ;;
    x86_64) node="$app_root/Resources/node/darwin-x64/node" ;;
    *) return 1 ;;
  esac
  [[ -x "$node" ]] || return 1
  printf '%s
' "$node"
}


if [[ "${1:-}" == "--terminal" ]]; then
  CONFIG_FILE="${2:-}"; [[ -f "$CONFIG_FILE" ]] || { echo "Missing launcher configuration."; exit 1; }
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"; rm -f "$CONFIG_FILE"
  APP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
  RUNTIME="$APP_ROOT/Resources/viewer"
  NODE_BIN="$(bundled_node "$APP_ROOT" || true)"
  [[ -n "$NODE_BIN" ]] || { echo "ERROR: This app does not contain a Node runtime for Mac architecture $(/usr/bin/uname -m)."; exit 33; }

  cleanup() {
    [[ -n "${LOCAL_SERVER_PID:-}" ]] && kill "$LOCAL_SERVER_PID" >/dev/null 2>&1 || true
    if [[ -n "${CONTROL_SOCKET:-}" && -S "$CONTROL_SOCKET" ]]; then /usr/bin/ssh -S "$CONTROL_SOCKET" -O exit "${USERNAME}@${HOST}" >/dev/null 2>&1 || true; fi
  }
  trap cleanup EXIT INT TERM

  if [[ "$MODE" == "local" ]]; then
    echo "Brainana Viewer Launcher"
    echo "========================"
    echo "Version: $APP_VERSION"
    echo "Build ID: $BUILD_ID"
    echo "Launcher path: $0"
    echo "Mode: Local Mac data"
    echo "Local runtime: $RUNTIME"
    echo "Viewer source: bundled locally"
    echo "Data directory: $OUTPUT_DIR"
    echo "Viewer: http://localhost:$VIEWER_PORT"
    echo
    "$NODE_BIN" "$RUNTIME/server.mjs" --port "$VIEWER_PORT" --output-dir "$OUTPUT_DIR" >"$APP_SUPPORT/local-viewer.log" 2>&1 &
    LOCAL_SERVER_PID=$!
    URL="http://localhost:$VIEWER_PORT"
    for attempt in $(seq 1 120); do
      if /usr/bin/curl -fsS --max-time 1 "$URL/api/config" >/dev/null 2>&1; then
        /usr/bin/open "$URL"
        wait "$LOCAL_SERVER_PID"
        exit $?
      fi
      kill -0 "$LOCAL_SERVER_PID" >/dev/null 2>&1 || { echo "ERROR: Local Viewer stopped before becoming available."; exit 44; }
      sleep 1
    done
    echo "ERROR: Local Viewer did not become available. See $APP_SUPPORT/local-viewer.log"
    exit 45
  fi

  CONTROL_DIR="$HOME/.brainana-viewer/ssh"; mkdir -p "$CONTROL_DIR"
  SAFE_NAME="$(printf '%s' "$PROFILE_NAME" | tr -cs 'A-Za-z0-9._-' '_')"
  CONTROL_SOCKET="$CONTROL_DIR/${SAFE_NAME}-$$.sock"
  CACHE_DIR="$HOME/Library/Caches/Brainana Viewer/$APP_VERSION/${SAFE_NAME}"

  echo "Brainana Viewer Launcher"
  echo "========================"
  echo "Version: $APP_VERSION"
  echo "Build ID: $BUILD_ID"
  echo "Launcher path: $0"
  echo "Connection: $PROFILE_NAME"
  echo "Viewer source: bundled locally on this Mac"
  echo "Remote data: ${USERNAME}@${HOST}:$OUTPUT_DIR"
  echo "Local viewer: http://localhost:$VIEWER_PORT"
  echo "Runtime model: local-only; no code is installed or executed on the workstation"
  echo "Local cache: $CACHE_DIR"
  echo
  echo "You may be asked for your SSH password, key passphrase, host confirmation, or Duo approval."

  /usr/bin/ssh -M -S "$CONTROL_SOCKET" -o ControlMaster=yes -o ControlPersist=600     -o ServerAliveInterval=30 -o ServerAliveCountMax=3     -fN "${USERNAME}@${HOST}" || exit $?

  echo "Checking workstation data access..."
  printf -v OUTPUT_Q '%q' "$OUTPUT_DIR"
  /usr/bin/ssh -S "$CONTROL_SOCKET" -o BatchMode=yes "${USERNAME}@${HOST}"     "test -d $OUTPUT_Q && test -r $OUTPUT_Q" || {
      echo "ERROR: The remote data directory does not exist or is not readable: $OUTPUT_DIR"
      exit 22
    }

  echo "Starting local Viewer with SSH filesystem access..."
  /bin/mkdir -p "$CACHE_DIR"
  "$NODE_BIN" "$RUNTIME/server.mjs"     --port "$VIEWER_PORT"     --mode workstation     --ssh-target "${USERNAME}@${HOST}"     --ssh-control "$CONTROL_SOCKET"     --remote-root "$OUTPUT_DIR"     --cache-dir "$CACHE_DIR"     >"$APP_SUPPORT/local-viewer.log" 2>&1 &
  LOCAL_SERVER_PID=$!

  URL="http://localhost:$VIEWER_PORT"
  for attempt in $(seq 1 180); do
    HEALTH="$(/usr/bin/curl -fsS --max-time 2 "$URL/api/health" 2>/dev/null || true)"
    if [[ "$HEALTH" == *'"version":"2.1.1"'* ]] && [[ "$HEALTH" == *'"mode":"workstation"'* ]]; then
      echo "Local runtime check: passed"
      /usr/bin/open "$URL"
      wait "$LOCAL_SERVER_PID"
      exit $?
    fi
    kill -0 "$LOCAL_SERVER_PID" >/dev/null 2>&1 || {
      echo "ERROR: Local Viewer stopped before becoming available."
      echo "See $APP_SUPPORT/local-viewer.log"
      /usr/bin/tail -n 40 "$APP_SUPPORT/local-viewer.log" 2>/dev/null || true
      exit 44
    }
    sleep 1
  done
  echo "ERROR: Viewer did not become available. See $APP_SUPPORT/local-viewer.log"
  exit 45

fi

MODE_PICK="$(choose_mode)" || exit 0
MODE="remote"; PROFILE_NAME=""; USERNAME=""; HOST=""; OUTPUT_DIR=""; REMOTE_PORT="5273"

if [[ "$MODE_PICK" == "Remote workstation" ]]; then
  ensure_profiles_file
  RANDOM_PORT="$(random_port)"
  SAVED_NAMES=(); while IFS= read -r n; do [[ -n "$n" ]] && SAVED_NAMES+=("$n"); done < <(profile_names)
  MENU=("${SAVED_NAMES[@]}" "Add a new connection..." "Delete a saved connection...")
  LAST="$(read_default lastRemoteProfile "${SAVED_NAMES[0]:-Penn workstation}")"
  PICKED="$(choose_from_lines "Brainana Viewer Launcher" "Choose a saved remote connection:" "$LAST" "${MENU[@]}")" || exit 0
  if [[ "$PICKED" == "Delete a saved connection..." ]]; then
    if ((${#SAVED_NAMES[@]} == 0)); then
      show_message "There are no saved connections to delete."
      exec "$0"
    fi
    TO_DELETE="$(choose_from_lines "Delete Connection" "Choose the connection to delete:" "${SAVED_NAMES[0]}" "${SAVED_NAMES[@]}")" || exit 0
    if [[ "$(ask_yes_no "Delete the saved connection ‘${TO_DELETE}’?")" == "Yes" ]]; then
      if delete_profile "$TO_DELETE"; then
        show_message "Deleted the saved connection ‘${TO_DELETE}’."
      else
        show_message "The saved connection could not be deleted."
      fi
    fi
    exec "$0"
  fi
  ORIGINAL=""
  if [[ "$PICKED" == "Add a new connection..." ]]; then
    PROFILE_NAME="$(ask_text "Name for this saved connection:" "New workstation")" || exit 0
    USERNAME="$(ask_text "Remote workstation username:" "")" || exit 0
    HOST="$(ask_text "Workstation hostname or IP address:" "")" || exit 0
    OUTPUT_DIR="$(ask_text "Brainana data directory on the workstation:" "")" || exit 0
    REMOTE_PORT="$(ask_text "Local Viewer port for this launch. A random candidate is provided; edit it for full control:" "$RANDOM_PORT")" || exit 0
  else
    load_profile "$PICKED" || { show_message "The selected connection could not be loaded."; exit 1; }
    ORIGINAL="$PROFILE_NAME"
    PROFILE_NAME="$(ask_text "Saved connection name:" "$PROFILE_NAME")" || exit 0
    USERNAME="$(ask_text "Remote workstation username:" "$USERNAME")" || exit 0
    HOST="$(ask_text "Workstation hostname or IP address:" "$HOST")" || exit 0
    OUTPUT_DIR="$(ask_text "Brainana data directory on the workstation:" "$OUTPUT_DIR")" || exit 0
    REMOTE_PORT="$(ask_text "Local Viewer port for this launch. A random candidate is provided; edit it for full control:" "$RANDOM_PORT")" || exit 0
  fi
  [[ -n "$PROFILE_NAME" && -n "$USERNAME" && -n "$HOST" && -n "$OUTPUT_DIR" ]] || { show_message "Connection name, username, host, and data directory are required."; exit 1; }
  [[ "$REMOTE_PORT" =~ ^[0-9]+$ ]] && ((REMOTE_PORT>=1024 && REMOTE_PORT<=65435)) || { show_message "The remote port must be between 1024 and 65435."; exit 1; }
  if [[ "$(ask_yes_no "Save these settings as ‘${PROFILE_NAME}’?")" == "Yes" ]]; then save_profile "$ORIGINAL" "$PROFILE_NAME" "$USERNAME" "$HOST" "$OUTPUT_DIR" "$REMOTE_PORT" || exit 1; fi
  save_default lastRemoteProfile "$PROFILE_NAME"
else
  MODE="local"
  DEFAULT_DIR="$(read_default localOutputDir "$HOME")"
  OUTPUT_DIR="$(choose_folder "Choose the local Brainana data folder." "$DEFAULT_DIR")" || exit 0
  OUTPUT_DIR="${OUTPUT_DIR%/}"; [[ -d "$OUTPUT_DIR" ]] || { show_message "The selected folder does not exist."; exit 1; }
  save_default localOutputDir "$OUTPUT_DIR"
fi

TUNNEL_PORT=""
if [[ "$MODE" == "remote" ]]; then
  VIEWER_PORT="$REMOTE_PORT"
  if ! port_is_free "$VIEWER_PORT"; then
    show_message "Local port ${VIEWER_PORT} is already in use. Relaunch and choose another port in the connection popup."
    exit 1
  fi
else
  SAVED_VIEWER_PORT="$(read_default localViewerPort 5173)"
  VIEWER_PORT="$(find_free_port "$SAVED_VIEWER_PORT" 5173)" || {
    show_message "No free local Viewer port was found between 5173 and 5373. Close any old Brainana Viewer or Align Terminal sessions and try again."
    exit 1
  }
  save_default localViewerPort "$VIEWER_PORT"
fi

CONFIG="$(/usr/bin/mktemp -t brainana-viewer-launcher.XXXXXX)" || exit 1
chmod 600 "$CONFIG"
for var in MODE PROFILE_NAME USERNAME HOST OUTPUT_DIR REMOTE_PORT VIEWER_PORT TUNNEL_PORT APP_VERSION BUILD_ID; do printf '%s=%q\n' "$var" "${!var}" >> "$CONFIG"; done
printf -v SELF_Q '%q' "$0"; printf -v CONFIG_Q '%q' "$CONFIG"; TERMINAL_CMD="$SELF_Q --terminal $CONFIG_Q"
/usr/bin/osascript -e 'on run argv' -e 'tell application "Terminal"' -e 'activate' -e 'do script (item 1 of argv)' -e 'end tell' -e 'end run' -- "$TERMINAL_CMD" >/dev/null
exit 0
