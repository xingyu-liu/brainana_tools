{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brainana.org/schemas/instance.schema.json",
  "title": "Brainana Viewer active instance",
  "type": "object",
  "required": ["schemaVersion", "version", "buildId", "pid", "port", "mode"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "version": { "type": "string" },
    "buildId": { "type": "string" },
    "pid": { "type": "integer", "minimum": 1 },
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "mode": { "enum": ["local", "workstation", "proxy"] }
  },
  "additionalProperties": true
}
