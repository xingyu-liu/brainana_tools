{
  "name": "brainana-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cross-platform NiiVue viewer for brainana pipeline output (source-first rebuild).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate-version": "node scripts/generate-version.mjs",
    "prebuild": "node scripts/generate-version.mjs",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "dev": "node core/launcher/launch.mjs --dev",
    "dev:web": "vite",
    "start": "node core/launcher/launch.mjs",
    "server": "node core/server/main.mjs",
    "test": "node scripts/run-tests.mjs"
  },
  "dependencies": {
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "@niivue/niivue": "^0.69.0",
    "fflate": "^0.8.2",
    "nifti-reader-js": "^0.8.0"
  }
}
